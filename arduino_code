#include <Servo.h>
#include <LiquidCrystal.h>
#include <Keypad.h>
#include <SPI.h>
#include <MFRC522.h>

// ---------------- PIN CONFIG ----------------
#define SS_PIN 10
#define RST_PIN 9
MFRC522 mfrc522(SS_PIN, RST_PIN);

const int irSensorPin = 2;
const int servoPin = 6;

// LCD: RS, E, D4, D5, D6, D7
LiquidCrystal lcd(7, 8, 5, 4, 3, A0);

Servo dispenserServo;

// ---------------- KEYPAD SETUP ----------------
const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte rowPins[ROWS] = {A1, A2, A3, A4};
byte colPins[COLS] = {A5, 11, 12, 13};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// ---------------- VARIABLES ----------------
int dispenseAngle = 90;
int initialAngle = 0;

String authorizedUID = "AB CD EF 12"; // Replace with your RFID UID
int dosage = 1;

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(9600);
  SPI.begin();
  mfrc522.PCD_Init();

  pinMode(irSensorPin, INPUT);

  dispenserServo.attach(servoPin);
  dispenserServo.write(initialAngle);

  lcd.begin(16, 2);
  lcd.print("Medicine System");
  delay(2000);
  lcd.clear();
}

// ---------------- LOOP ----------------
void loop() {
  lcd.setCursor(0, 0);
  lcd.print("Scan RFID Card ");

  if ( ! mfrc522.PICC_IsNewCardPresent()) return;
  if ( ! mfrc522.PICC_ReadCardSerial()) return;

  String content = "";
  for (byte i = 0; i < mfrc522.uid.size; i++) {
    content += String(mfrc522.uid.uidByte[i] < 0x10 ? " 0" : " ");
    content += String(mfrc522.uid.uidByte[i], HEX);
  }
  content.toUpperCase();

  if (content.substring(1) == authorizedUID) {
    lcd.clear();
    lcd.print("Access Granted");
    delay(1500);
    
    selectDosage();
  } else {
    lcd.clear();
    lcd.print("Access Denied");
    delay(2000);
    lcd.clear();
  }
}

// ---------------- DOSAGE SELECTION ----------------
void selectDosage() {
  lcd.clear();
  lcd.print("Enter Dosage:");
  lcd.setCursor(0, 1);

  String input = "";

  while (true) {
    char key = keypad.getKey();
    
    if (key) {
      if (key >= '0' && key <= '9') {
        input += key;
        lcd.print(key);
      } 
      else if (key == '#') {
        dosage = input.toInt();
        break;
      }
      else if (key == '*') {
        input = "";
        lcd.clear();
        lcd.print("Re-enter:");
        lcd.setCursor(0,1);
      }
    }
  }

  lcd.clear();
  lcd.print("Place Container");
  
  waitForContainer();
}

// ---------------- WAIT FOR IR SENSOR ----------------
void waitForContainer() {
  while (digitalRead(irSensorPin) == HIGH) {
    delay(200);
  }

  dispenseMedicine();
}

// ---------------- DISPENSE FUNCTION ----------------
void dispenseMedicine() {
  lcd.clear();
  lcd.print("Dispensing...");

  for (int i = 0; i < dosage; i++) {
    dispenserServo.write(dispenseAngle);
    delay(1500);

    dispenserServo.write(initialAngle);
    delay(1000);
  }

  lcd.clear();
  lcd.print("Done!");
  lcd.setCursor(0,1);
  lcd.print("Take Medicine");

  delay(3000);
  lcd.clear();
}
